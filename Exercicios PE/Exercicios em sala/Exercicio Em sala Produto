##include <stdio.h>
#include <stdlib.h>
#define CARACTERES 200
#define TAM 2

struct Produto{
	int codigo;
	char descricao[CARACTERES];
	double v_unitario;
	int qtd_estoque;
};



//funcoes auxliares
int qtdStr(char texto[]){
    int i = 0;
    while(texto[i] != '\0'){
        i += 1;
    }
    return i;
}

void lerStr(char str[], int max){
    fgets(str, max, stdin);
    int tam = qtdStr(str);
    if(tam > 0 && str[tam - 1] == '\n'){
        str[tam - 1] = '\0';
    }
}


//funcao letra A
void preencher(struct Produto *P, int i){
	printf("\n*AREA DE CADASTRO DO PRODUTO*\n");
	printf("\nDigite o codigo do produto: ");
	scanf("%d", &P[i].codigo);
	printf("\nDigite a descricao do produto: ");
	lerStr(P[i].descricao, CARACTERES);
	lerStr(P[i].descricao, CARACTERES);
	printf("\nDigite o valor Unitario do produto: ");
	scanf("%lf", &P[i].v_unitario);
	printf("\nDigite a quantidade no estoque: ");
	scanf("%d", &P[i].qtd_estoque);   }		
	
//funcao Letra G

void Exibir(struct Produto *P, int tamanho){
	printf("\n*AREA EXIBIR CODIGO E A DESCRICAO DE TODOS OS PRODUTOS*\n");
	for(int i = 0; i < tamanho; i++){
		printf("\nCODIGO: %d", P[i].codigo);
		printf("\nDESCRICAO: %s", P[i].descricao);
	}
	printf("\n*FIM DA AREA DE EXIBICAO DE CODIGO E DESCRICAO!*\n");
}


int buscaSequencial(struct Produto vp[], int n, int x) { //sendo n o tamanho, x o valor que estamos procurando
    for (int i = 0; i < n; i += 1) {
        if (vp[i].codigo == x) {
            return i; //achou retorna o indice 
        }
    }
    return -1; //se nao achou retorna -1
}

void AlterarVu(struct Produto produto[], int tamanho){
	printf("=====AREA ALTERAR VALOR UNITARIO PELO CODIGO====");
	printf("\nDigite o codigo do produto que voce deseja alterar: ");
	int codigo;
	scanf("%d", &codigo);
	int pos = buscaSequencial(produto, tamanho, codigo);
	
	if(pos >= 0 ){
		printf("\nQual o valor que voce deseja nesse produto?: ");
		double preco;
		scanf("%lf", &produto[pos].v_unitario);
	}
	printf("\nO codigo nao existe no sistema!");
}





int main() {
	struct Produto meuVet[TAM];
	int entrada = 1;
	int i = 0;

	do{
        printf("\n----------");
		printf("\n*MENU*\n");
		printf("1 - Cadastrar Novo Produto");
		printf("\n2 - Alterar Valor unitario");
		printf("\n7 - Exibir codigo e descricao de todos os produtos\n");
        printf("\nDigite a sua escolha do menu: ");
		scanf("%d", &entrada);
		
		if(entrada == 1){
            if (i >= TAM)
            {
                printf("\nLIMITE ATINGIDO!");
                continue;
            }
            preencher(meuVet, i);
            i += 1;
		}
        else if(entrada == 7){
            Exibir(meuVet, i);
        }
        else if(entrada == 2){
        	AlterarVu(meuVet, TAM);
		}
        else if(entrada == 0){
            printf("\nPROGRAMA ENCERRADO!");
        }
	}while(entrada != 0);
	
	
	
	
	return 0;
}
