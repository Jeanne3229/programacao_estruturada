//Agora a inserção ordenada por meio do metodo insertion sort:

void ordenar_vetor(int v[]; int tamanho) {
  int i, anterior, atual;
  for(i = 1; i < tamanho; i++) {
    atual = v[i];
    anterior = i - 1
    while(anterior >= 0 && v[anterior] > atual) {
      v[anterior + 1] = v[anterior]
      anterior = anterior - 1; }
  v[anterior + 1] = atual;






