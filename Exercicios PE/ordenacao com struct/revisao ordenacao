void ordenarPornomeB(struct Aluno v[], int n){ //ordenar por nome crescente
    int i, fim, pos, troca;
    struct Aluno chave;
    troca = 1; fim = n - 2; pos = 0;
    while(troca == 1){
        troca = 0;
        for(i = 0; i <= fim; i++){
            if(strcmp(v[i].nome, chave.nome) > 0){ //
                chave = v[i];
                v[i] = v[i + 1];
                v[i + 1] = chave;
                pos = i;
                troca = 1;
            }
        }
    }
}


void ordenarPorNotaI(struct Aluno v[], int n){ //insertion ordenar decrescente 
    int i, j;
    struct Aluno chave;
    for(i = 0; i <= n - 1; i++){
        chave = v[i];
        j = i - 1;
        while(j >= 0 && v[j].nota < chave.nota){
            v[j + 1] = v[j];
            j -= 1;
        }
        v[j + 1] = chave;
    }
    }


int main()
{
    struct Aluno vet[MAX];
    preencher(vet, MAX);
    ordenarPorNotaI(vet, MAX);
    exibirAlunos(vet, MAX);
