include <stdio.h>
#include <stdlib.h>
#include <string.h>
#define CARACTERES 50
#define MAX 2

struct Aluno{
    int matricula;
    char nome[CARACTERES];
    double nota;
};

int qtdStr(char texto[]){
    int i = 0;
    while (texto[i] != '\0'){ // literais caractereres devem ser utilizados com aspas simples
        i += 1;
    }
    return i;
}


void lerStr(char str[], int max){
    fgets(str, max, stdin);
    int tam = qtdStr(str);
    if (tam > 0 && str[tam - 1] == '\n'){
        str[tam - 1] = '\0';
    }
}

void preencher(struct Aluno *A, int tamanho){
    for(int i = 0; i < tamanho; i++){
        printf("\nDigite a matricula [%d]: ", i);
        scanf("%d", &A[i].matricula);
        getchar();
        printf("\nDigite o nome [%d]: ", i);
        lerStr(A[i].nome, CARACTERES);
        printf("\nDigite a nota [%d]: ", i);
        scanf("%lf", &A[i].nota);
        getchar();
    }
}

void exibiraluno(struct Aluno *A, int tamanho){
    printf("\nDigite a matricula do aluno que voce deseja que seja exibido: ");
    int escolha;
    scanf("%d", &escolha);
    for(int i = 0; i < tamanho; i++){
        if(escolha == A[i].matricula){
            printf("\nMATRICULA DO ALUNO: %d", A[i].matricula);
            printf("\nNOME DO ALUNO: %s", A[i].nome);
            printf("\nNOTA DO ALUNO: %lf\n", A[i].nota);
        }
    }
}


void exibirAlunos(struct Aluno *A, int tamanho){
    for(int i = 0; i < tamanho; i++){
        printf("\nMATRICULA DO ALUNO: %d", A[i].matricula);
        printf("\nNOME DO ALUNO: %s", A[i].nome);
        printf("\nNOTA DO ALUNO: %lf\n", A[i].nota);
    }
}


