#include <stdio.h>
#include <stdlib.h>
#define TAM 200
#define MAX 2

struct Produto{
    int codigo;
    char descricao[TAM];
    int quantidade;
};

int qtdStr(char texto[]){
    int i = 0;
    while(texto[i] != '\0'){
        i += 1;
    }
    return i;}


void LerStr(char str[], int max){
    fgets(str, max, stdin);
    int tam  = qtdStr(str);
    if(tam > 0 && str[tam - 1] == '\n'){
        str[tam - 1] = '\0';
    }
}


void preencher(struct Produto *P, int tamanho){
    for(int i = 0; i < tamanho; i++){
        printf("\nDigite o codigo do produto[%d]: ", i);
        scanf("%d", &P[i].codigo);
        getchar();
        printf("\nDigite a descricao do produto[%d]: ", i);
        LerStr(P[i].descricao, TAM);
        printf("\nDigite a quantidade do produto[%d]: ", i);
        scanf("%d", &P[i].quantidade);
        getchar();
    }
}


void Exibir(struct Produto *P, int tamanho){
    for(int i = 0; i < tamanho; i++){
        printf("\n*PRODUTOS*\n");
        printf("\nCODIGO: %d", P[i].codigo);
        printf("\nDESCRICAO: %s", P[i].descricao);
        printf("\nQUANTIDADE: %d", P[i].quantidade);
    }
}

void selectionSort(struct Produto v[], int n){
    int i, j, menor;
    struct Produto aux;
    for(i = 0; i < n - 1; i += 1){
        menor = i;
        for(j = i + 1; j <= n - 1; j += 1){
            if(v[j].codigo < v[menor].codigo){
                menor = j;


            }
        }
    aux = v[i];
    v[i] = v[menor];
    v[menor] = aux;
    }
}



int main()
{
    struct Produto vet[MAX];
    preencher(vet, MAX);
    Exibir(vet, MAX);
    selectionSort(vet, MAX);
    printf("\nORDENADO: \n");
    Exibir(vet, MAX);


    return 0;
}
