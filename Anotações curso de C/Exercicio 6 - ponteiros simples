#include <stdio.h>
#include <stdlib.h>

//Crie uma função que receba dois numeros por ponteiro e altera o maior deles para 0

void maior(int *v1, int *v2) {
  if(*v1 > *v2) {
    *v1 = 0;
    printf("n1 e: %d \tn2 e:%d\n", *v1, *v2); }
  else {
    *v2 = 0;
     printf("n1 e: %d \tn2 e:%d\n", *v1, *v2); }  }
    




int main() {
  int n1 = 5;
  int n2 = 10;
