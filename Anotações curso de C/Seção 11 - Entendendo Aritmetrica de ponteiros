#include <stdio.h>
#include <stdlib.h>

//funcao para imprimir um vetor usando aritmetrica de ponteiros

void imprimir(int *n, int tamanho) {
    printf("\n\t");
    for(int i = 0; i < tamanho; i++) {
        printf("%d ", *(n + i)); //i fala em relação ao indice
    }
}

