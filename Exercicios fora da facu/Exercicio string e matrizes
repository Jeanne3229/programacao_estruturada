Letras minúsculas: 12
Letras maiúsculas: 4

//RESPOSTA SEM A BIBLIOTECA DE PREFERENCIA

#include <stdio.h>
#include <stdlib.h>
#define MAX 100

//primeiro vai contar o tamanho da string
int meuStrLen(char str[]) {
    int tam = 0;
    while(str[tam] != '\0') {
        tam += 1;
    }
    return tam;
}

//vai checar as minusculas
int ehMinuscula(char caractere) {
    return caractere >= 'a' && caractere <= 'z';
}
//vai checar as maiusculas
int ehMaiuscula(char caractere) {
    return caractere >= 'A' && caractere <= 'Z';
}
//funcao final juntando todas
void contar(char v[], int tamanho) {
    printf("Digite sua frase: ");
    fgets(v, tamanho, stdin);
    int tamanho1 = meuStrLen(v);
    if(tamanho1 > 0 && v[tamanho1 - 1] == '\n') { //aqui ele vai tirar o enter da contagem do tamanho
        tamanho1--;
    }
    int conta_espaco = 0; //contagem de cada variavel
    int conta_Maiuscula = 0;
    int conta_Minuscula = 0;
    for(int i = 0; i < tamanho1; i++) {
        if(ehMinuscula(v[i])){
            conta_Minuscula += 1;
        }
        if(ehMaiuscula(v[i])) {
            conta_Maiuscula += 1;
        }
        if (v[i] == ' ') {
            conta_espaco += 1;
        }
    }
    printf("\n\nLetras Minusculas: %d", conta_Minuscula); //prints fora do for
    printf("\nLetras Maiusculas: %d", conta_Maiuscula);
    printf("\n\nEspacos: %d", conta_espaco);
