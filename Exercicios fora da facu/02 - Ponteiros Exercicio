    printf("\nDigite o valor de n2: ");
    scanf("%d", n2);
    printf("\nEndereco de n1: %p", n1);
    printf("\nEndereco de n2: %p", n2);
    if(n1 > n2) {
        printf("\nO endereco de n1 e maior que n2");
    }
    else{
        printf("\no endereco de n2 e maior que n1\n");
    }



}



int main()
{
