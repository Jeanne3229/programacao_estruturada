#include <stdio.h>
#include <stdlib.h>

//Escreva um programa que contenha duas variaveis inteiras. Compare seus enderecos e exiba o maior endereço

void maior(int *n1, int *n2) { //*n1 fala sobre o valor
    printf("Endereco de n1: %p", n1); //aqui fala sobre o ENDERECO
    printf("\nEndereco de n2: %p", n2);
    if(n1 > n2) { //COMPARANDO ENDERECOS !
        printf("\nO endereco de n1 e maior que o de n2!\n");
    }
    else{
        printf("\nO endereco de n2 e maior que o de n1!\n");

    }
}



int main()
{
    int n1 = 10;
    int n2 = 500;
    int *ps1 = &n1;
    int *ps2 = &n2;
    maior(ps1,ps2);



    return 0;
}
